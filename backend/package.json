{
  "name": "swiftserve-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "migrate": "node-pg-migrate",
    "migrate:up": "docker exec swiftserve-api-1 sh -c \"DATABASE_URL='postgres://user:password@db:5432/swiftserve_db' npx node-pg-migrate up -m /app/migrations\"",
    "migrate:down": "docker exec swiftserve-api-1 sh -c \"DATABASE_URL='postgres://user:password@db:5432/swiftserve_db' npx node-pg-migrate down -m /app/migrations\"",
    "migrate:create": "node-pg-migrate create",
    "migrate:up:local": "DATABASE_URL=\"postgres://user:password@localhost:5432/swiftserve_db\" npx node-pg-migrate up -m ./migrations",
    "migrate:down:local": "DATABASE_URL=\"postgres://user:password@localhost:5432/swiftserve_db\" npx node-pg-migrate down -m ./migrations"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.11.5",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.0"
  },
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs"
}
